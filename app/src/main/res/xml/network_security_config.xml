<?xml version="1.0" encoding="utf-8"?>
<!-- Network Security Config: TLS 1.2/1.3 only, modern certificates -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Use system trusted CAs (updated CA store) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow specific hosts with pinning for Yandex -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">music.yandex.ru</domain>
        <domain includeSubdomains="true">api.music.yandex.net</domain>
        <domain includeSubdomains="true">avatars.yandex.net</domain>
        <domain includeSubdomains="true">oauth.yandex.ru</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
