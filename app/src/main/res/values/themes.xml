<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme - dark OLED style -->
    <style name="Theme.WindYM" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_red</item>
        <item name="colorPrimaryVariant">@color/brand_red_dark</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        <item name="colorSecondary">@color/brand_red_light</item>
        <item name="colorOnSecondary">@color/text_on_brand</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_secondary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialButtonStyle">@style/Widget.WindYM.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.WindYM.BottomNav</item>
    </style>

    <!-- Splash / Auth screen -->
    <style name="Theme.WindYM.Splash" parent="Theme.WindYM">
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.WindYM.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="backgroundTint">@color/brand_red</item>
        <item name="cornerRadius">2dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="Widget.WindYM.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/brand_red</item>
        <item name="strokeColor">@color/brand_red</item>
        <item name="cornerRadius">2dp</item>
    </style>

    <style name="Widget.WindYM.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/brand_red</item>
    </style>

    <style name="Widget.WindYM.Button.Icon" parent="Widget.MaterialComponents.Button.Icon">
        <item name="backgroundTint">@color/bg_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="iconTint">@color/brand_red</item>
        <item name="cornerRadius">2dp</item>
    </style>

    <!-- Base Widget style (required for dot-notation inheritance) -->
    <style name="Widget.WindYM" parent="android:Widget" />

    <!-- Bottom Navigation -->
    <style name="Widget.WindYM.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_secondary</item>
        <item name="itemIconTint">@color/nav_icon_tint</item>
        <item name="itemTextColor">@color/nav_icon_tint</item>
        <!-- nav_icon_tint is defined in res/color/nav_icon_tint.xml -->
        <item name="elevation">8dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.WindYM.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">2dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <!-- Track item -->
    <style name="Widget.WindYM.TrackCard" parent="Widget.WindYM.Card">
        <item name="cardCornerRadius">2dp</item>
    </style>

    <!-- Text input -->
    <style name="Widget.WindYM.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_surface</item>
        <item name="boxStrokeColor">@color/stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusTopEnd">0dp</item>
        <item name="boxCornerRadiusTopStart">0dp</item>
    </style>

    <!-- Player bottom sheet -->
    <style name="Widget.WindYM.PlayerBar" parent="Widget.WindYM">
        <item name="android:background">@color/player_bg</item>
        <item name="android:elevation">16dp</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.WindYM" parent="android:TextAppearance" />

    <style name="TextAppearance.WindYM.Title" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.WindYM.TrackTitle" parent="TextAppearance.AppCompat.Subhead">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TextAppearance.WindYM.TrackSubtitle" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TextAppearance.WindYM.NowPlaying" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textColor">@color/brand_red</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.WindYM.Logo" parent="TextAppearance.AppCompat.Display1">
        <item name="android:textColor">@color/brand_red</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
